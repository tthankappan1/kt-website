# Copy to .env.local (never committed). Set the same values in the Vercel dashboard.
#
# USE THE NEW API KEYS (publishable + secret). In the Supabase dashboard go to
# Settings → API Keys; if you don't have one yet, click "Create new API keys",
# then copy the Publishable key and a Secret key. Do NOT use the deprecated
# legacy anon/service_role JWT keys (legacy support ends 2026).
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_…). Uses the `anon` role — respects RLS, safe
# to expose client-side. Reserved for future client use; current code does not read it.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_…). Uses the `service_role` role — BYPASSES RLS and is
# the ONLY write path for /api/lead + /api/newsletter. Server-only; NEVER expose
# client-side (Supabase 401s a secret key sent from a browser). Pasting the
# publishable/anon key here makes every insert fail RLS — the app throws a clear
# startup error if it detects an RLS-respecting key in this slot.
SUPABASE_SECRET_KEY=
# Optional v1: lead-notification email via Resend (not wired yet)
RESEND_API_KEY=
# Server-only preview flag — set to "true" ONLY on a non-production preview
# deploy to render draft blog posts. Ignored when NODE_ENV=production (drafts
# can never ship to production). Do NOT prefix with NEXT_PUBLIC_.
SHOW_DRAFTS=
