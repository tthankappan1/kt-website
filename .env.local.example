# Copy to .env.local (never committed). Set the same values in the Vercel dashboard.
#
# USE THE LEGACY API KEYS. In the Supabase dashboard go to
# Settings → API → "Legacy API Keys" and copy the JWT-format `anon` and
# `service_role` keys. Do NOT use the new sb_publishable_… / sb_secret_… keys
# here (a prior project hit issues with them; the codebase is wired for the
# legacy anon + service_role scheme).
NEXT_PUBLIC_SUPABASE_URL=
# Legacy `anon` key (JWT, role: anon). Respects RLS — safe to expose client-side.
# Reserved for future client use; the current code does not read it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Legacy `service_role` key (JWT, role: service_role). BYPASSES RLS — this is the
# ONLY write path for /api/lead + /api/newsletter. Server-only; NEVER expose
# client-side. Pasting the anon key here will make every insert fail RLS
# (the app throws a clear error at startup if it detects an anon/publishable key).
SUPABASE_SERVICE_ROLE_KEY=
# Optional v1: lead-notification email via Resend (not wired yet)
RESEND_API_KEY=
# Server-only preview flag — set to "true" ONLY on a non-production preview
# deploy to render draft blog posts. Ignored when NODE_ENV=production (drafts
# can never ship to production). Do NOT prefix with NEXT_PUBLIC_.
SHOW_DRAFTS=
