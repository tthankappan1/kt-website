# Copy to .env.local (never committed). Set the same values in the Vercel dashboard.
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by /api/lead and /api/newsletter. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
# Optional v1: lead-notification email via Resend (not wired yet)
RESEND_API_KEY=
# Server-only preview flag — set to "true" ONLY on a non-production preview
# deploy to render draft blog posts. Ignored when NODE_ENV=production (drafts
# can never ship to production). Do NOT prefix with NEXT_PUBLIC_.
SHOW_DRAFTS=
